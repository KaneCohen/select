{
  "name": "@cohensive/select",
  "version": "0.6.3",
  "description": "Select",
  "private": true,
  "keywords": [
    "select",
    "combobox",
    "tagging",
    "tokens",
    "tokenizer",
    "chips",
    "autocomplete",
    "input"
  ],
  "author": {
    "name": "Kane Cohen",
    "email": "kanecohen@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KaneCohen/select.git"
  },
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.31.0",
    "@preconstruct/cli": "^2.8.12",
    "@types/node": "^24.10.1",
    "autoprefixer": "^10.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "preconstruct": {
    "packages": [
      "packages/*"
    ]
  },
  "browser": {},
  "scripts": {
    "dev": "preconstruct dev && npm run theme",
    "watch": "sh -c 'npm run theme && npm run theme:watch & preconstruct watch'",
    "build": "preconstruct build",
    "theme": "sh -c 'tailwindcss -i ./packages/core/src/theme.css > ./packages/core/dist/select.css'",
    "theme:watch": "tailwindcss -i ./packages/core/src/theme.css -o ./packages/core/dist/select.css --watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && npm run theme && changeset publish"
  }
}
