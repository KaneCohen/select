{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["es2018", "dom"],
    "module": "esnext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/declarations",
    "outDir": "dist/declarations",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "skipLibCheck": true,
    "paths": {
      "@cohensive/select-core": ["../core"],
      "@cohensive/select-core/types": ["../core/types"],
      "@cohensive/select-core/defaults": ["../core/defaults"]
    }
  },
  "references": [
    {
      "path": "../core"
    }
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "include": [
    "src/**/*.ts",
    "vue.d.ts"
  ]
}
